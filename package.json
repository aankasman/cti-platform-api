{
    "name": "cti-platform-api",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@9.0.0",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "test": "turbo test",
        "lint": "turbo lint",
        "clean": "turbo clean && rm -rf node_modules",
        "db:generate": "turbo db:generate",
        "db:migrate": "turbo db:migrate",
        "db:push": "turbo db:push",
        "db:studio": "pnpm --filter @rinjani/db studio"
    },
    "devDependencies": {
        "turbo": "^2.0.0",
        "typescript": "^5.4.0"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    },
    "pnpm": {
        "overrides": {
            "@tanstack/react-router": ">=1.169.9",
            "@tanstack/router-core": ">=1.169.9",
            "@tanstack/history": ">=1.161.13",
            "protobufjs": ">=7.5.5"
        },
        "//overrides": "Supply-chain + critical-RCE floors. The @tanstack/* floors keep the 2026-05-11 Shai-Hulud worm versions (CVE-2026-45321: react-router/router-core 1.169.5-1.169.8, history 1.161.9-1.161.12) from ever resolving even if a transitive range widens. protobufjs >=7.5.5 patches the arbitrary-code-execution advisory in the OpenTelemetry chain. See SECURITY_AUDIT.md."
    }
}