{
    "name": "v3-backend-api-rinjani",
    "version": "0.1.0",
    "private": true,
    "packageManager": "pnpm@9.0.0",
    "scripts": {
        "dev": "turbo dev",
        "build": "turbo build",
        "test": "turbo test",
        "lint": "turbo lint",
        "clean": "turbo clean && rm -rf node_modules",
        "db:generate": "turbo db:generate",
        "db:migrate": "turbo db:migrate",
        "db:push": "turbo db:push",
        "db:studio": "pnpm --filter @rinjani/db studio"
    },
    "devDependencies": {
        "turbo": "^2.0.0",
        "typescript": "^5.4.0"
    },
    "engines": {
        "node": ">=20.0.0",
        "pnpm": ">=9.0.0"
    }
}