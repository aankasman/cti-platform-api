# Environment Configuration

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rinjani_v3

# OpenSearch
OPENSEARCH_URL=http://localhost:9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=admin

# API
PORT=3001
NODE_ENV=development

# JWT — required. Generate with: openssl rand -hex 32
JWT_SECRET=

# External API (optional, for syncing from external sources)
EXTERNAL_API_URL=http://localhost:4000
EXTERNAL_API_TOKEN=your-api-token

# ─── OAuth (Google + GitHub) ──────────────────────────────────────────────
# Where the dashboard lives — used to redirect back after a successful
# OAuth callback. Defaults to http://localhost:3000 if unset.
DASHBOARD_URL=http://localhost:3000

# Public-facing URL the OAuth providers will redirect to. Defaults to
# http://localhost:${PORT}. Must match the redirect URI registered with the
# provider (e.g. http://localhost:3001/auth/oauth/google/callback).
API_PUBLIC_URL=http://localhost:3001

# Google OAuth — get from https://console.cloud.google.com/apis/credentials
# Authorised redirect URI to add: ${API_PUBLIC_URL}/auth/oauth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# GitHub OAuth — get from https://github.com/settings/developers
# Authorisation callback URL to set: ${API_PUBLIC_URL}/auth/oauth/github/callback
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=

# Comma-separated emails that should be created with role=admin on first
# OAuth sign-in. Everyone else lands as 'viewer'. Case-insensitive.
ADMIN_EMAILS=

# ─── NIST NVD (CVE / CVSS / publication-date enrichment) ──────────────────
# Get a key from https://nvd.nist.gov/developers/request-an-api-key (free).
# Without one we're throttled to 5 requests / 30s; with one, ~50 req / 30s
# (9× throughput). Used by:
#   - apps/api/src/services/feedSync/nvdSync.ts          (scheduled NVD sync)
#   - apps/api/src/queues/workers/cveEnrichmentWorker.ts (CVE enrich worker)
#   - apps/api/src/services/vulnerabilityEnrichment.ts   (on-demand enrichment)
# NVD_API_KEY is the canonical name (matches NIST's portal). The codebase
# also accepts CVE_API_KEY as a legacy alias — if both are set, NVD_API_KEY
# wins.
NVD_API_KEY=

# ─── LLM Providers (for embeddings + actor enrichment) ────────────────────
# At least one of GEMINI_API_KEY / GOOGLE_API_KEY / OPENROUTER_API_KEY must
# be set for AI features (similar-search, actor enrichment) to work.
# When OPENROUTER_API_KEY is set, it becomes the default for actor
# enrichment (better JSON adherence than Gemini free flash in our testing).
GEMINI_API_KEY=
OPENROUTER_API_KEY=

# Optional overrides — force a specific provider/model for actor enrichment.
# Provider must be one of: openrouter, gemini, ollama.
# Model is provider-specific:
#   openrouter — 'google/gemini-2.5-flash' (default), 'openai/gpt-4o-mini', 'anthropic/claude-haiku-4.5'
#   gemini     — 'gemini-2.5-flash' (default), 'gemini-2.5-pro'
ACTOR_ENRICHMENT_PROVIDER=
ACTOR_ENRICHMENT_MODEL=

# Workbench — embedded BullMQ dashboard at /admin/workbench (proxied through
# the Next.js dashboard). Auth is delegated to our own session middleware
# (`requireAuth + requireRole('admin')`) via the dashboard-set `rinjani_token`
# cookie — no separate Workbench credentials needed. Toggle below hides
# retry / remove / promote actions when set to `true`.
WORKBENCH_READONLY=false
