{
    "name": "@rinjani/worker",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "_comment": "BullMQ workers + scheduler + work listener now run inside the @rinjani/api process. This package only ships one-off CLI helpers and the legacy standalone feed-sync daemon (kept for emergency use).",
        "build": "tsc",
        "dev:standalone": "tsx watch src/index.ts",
        "start:standalone": "node dist/index.js",
        "sync": "tsx src/sync.ts",
        "sync:daemon": "tsx src/index.ts",
        "sync:feeds": "tsx src/feeds/index.ts all",
        "sync:alienvault": "tsx src/feeds/index.ts alienvault",
        "sync:cisa": "tsx src/feeds/index.ts cisa",
        "sync:abusessl": "tsx src/feeds/index.ts abusessl",
        "feeds:daemon": "tsx src/feeds/index.ts daemon"
    },
    "dependencies": {
        "@rinjani/core": "workspace:*",
        "@rinjani/db": "workspace:*",
        "bullmq": "^5.77.3",
        "dotenv": "^17.2.3",
        "drizzle-orm": "^0.30.0",
        "ioredis": "^5.10.1"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "tsx": "^4.7.0",
        "typescript": "^5.4.0"
    }
}